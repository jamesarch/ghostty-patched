 macos/Sources/Ghostty/Ghostty.App.swift | 51 +++++++++++++++++++++++++
 src/Surface.zig                         |  6 +++
 src/apprt/action.zig                    | 24 ++++++++++++
 src/apprt/gtk/class/application.zig     |  4 ++
 src/input/Binding.zig                   |  9 +++++
 src/input/command.zig                   |  1 +
 7 files changed, 103 insertions(+)

