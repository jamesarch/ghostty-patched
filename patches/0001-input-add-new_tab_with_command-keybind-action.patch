 // apprt.action.CloseTabMode
 typedef enum {
   GHOSTTY_ACTION_CLOSE_TAB_MODE_THIS,
@@ -949,6 +955,7 @@ typedef enum {
   GHOSTTY_ACTION_SEARCH_SELECTED,
   GHOSTTY_ACTION_READONLY,
   GHOSTTY_ACTION_COPY_TITLE_TO_CLIPBOARD,
